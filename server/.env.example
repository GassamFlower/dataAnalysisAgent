# DeepSeek API
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro

# 备选 LLM（Kimi / Qwen）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_K3_MODEL=kimi-k3
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_37_MAX_MODEL=qwen3.7-max
QWEN_36_FLASH_MODEL=qwen3.6-flash

# 服务
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# 前端地址（CORS）
FRONTEND_URL=http://localhost:3000

# 数据库（开发环境默认 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data_analysis_agent.db

# 安全（JWT）
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 安全（密码重置 JWT）—— 必须与 JWT_SECRET_KEY 不同
RESET_JWT_SECRET_KEY=your_reset_jwt_secret_key_here

# 开发模式（仅 DEBUG=true 时允许 dev-token）
DEV_TOKEN=dev-token
ALLOW_DEV_TOKEN=true

# 微信公众号网页授权
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# 邮件 SMTP 配置
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=预演

# 速率限制
RATE_LIMIT_PER_MINUTE=60

# 套餐限制
FREE_PLAN_PROJECT_LIMIT=3
FREE_PLAN_SIMULATION_LIMIT_PER_WEEK=3
FREE_PLAN_EXPORT_LIMIT_PER_WEEK=3
