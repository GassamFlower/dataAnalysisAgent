# 生产环境变量示例
# 部署时通过系统环境变量注入，本文件仅作 fallback 参考

ENVIRONMENT=production

# 服务
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 前端地址（CORS）
FRONTEND_URL=https://your-domain.com

# 数据库（生产环境 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/data_analysis_agent

# 安全（JWT）
JWT_SECRET_KEY=change_to_strong_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 开发模式（生产环境必须关闭）
ALLOW_DEV_TOKEN=false

# 微信公众号网页授权
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://your-domain.com/api/auth/callback

# 邮件 SMTP 配置
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=预演

# 速率限制
RATE_LIMIT_PER_MINUTE=60

# 套餐限制
FREE_PLAN_PROJECT_LIMIT=3
FREE_PLAN_SIMULATION_LIMIT_PER_WEEK=3
FREE_PLAN_EXPORT_LIMIT_PER_WEEK=3

# LLM（生产必填）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_K3_MODEL=kimi-k3
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_37_MAX_MODEL=qwen3.7-max
QWEN_36_FLASH_MODEL=qwen3.6-flash
